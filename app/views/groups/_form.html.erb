<%= form_with(model: group) do |form| %>
  <% if group.errors.any? %>
    <div style="color: red">
      <h3>No se pudo guardar el grupo.</h3>

      <ul>
        <% group.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, "Nombre del grupo" %>
    <%= form.text_field :name, placeholder: "Ejemplo: A" %>
  </div>

  <div>
    <%= form.submit "Guardar grupo" %>
  </div>
<% end %>