<%= form_with(model: team) do |form| %>
  <% if team.errors.any? %>
    <div class="alert error">
      <h3>No se pudo guardar la selección.</h3>

      <ul>
        <% team.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Campo principal para registrar el nombre del país participante. %>
  <div>
    <%= form.label :country_name, "Nombre del país" %>
    <%= form.text_field :country_name, placeholder: "Ejemplo: Argentina" %>
  </div>

  <%# El grupo se selecciona desde los grupos registrados para evitar escribir IDs manualmente. %>
  <div>
    <%= form.label :group_id, "Grupo asignado" %>
    <%= form.collection_select :group_id, Group.order(:name), :id, :name, prompt: "Seleccione un grupo" %>
  </div>

  <%# Las estadísticas forman parte del requerimiento del proyecto. %>
  <%# Aunque se muestran en el formulario, el sistema las recalcula con los partidos jugados. %>
  <div>
    <%= form.label :points, "Puntos" %>
    <%= form.number_field :points, min: 0 %>
  </div>

  <div>
    <%= form.label :goals_for, "Goles a favor" %>
    <%= form.number_field :goals_for, min: 0 %>
  </div>

  <div>
    <%= form.label :goals_against, "Goles en contra" %>
    <%= form.number_field :goals_against, min: 0 %>
  </div>

  <div>
    <%= form.label :goal_difference, "Diferencia de goles" %>
    <%= form.number_field :goal_difference %>
  </div>

  <div>
    <%= form.submit "Guardar selección" %>
  </div>
<% end %>