<%= form_with(model: team) do |form| %>
  <% if team.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(team.errors.count, "error") %> prohibited this team from being saved:</h2>

      <ul>
        <% team.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :country_name, style: "display: block" %>
    <%= form.text_field :country_name %>
  </div>

  <div>
    <%= form.label :group_id, style: "display: block" %>
    <%= form.text_field :group_id %>
  </div>

  <div>
    <%= form.label :points, style: "display: block" %>
    <%= form.number_field :points %>
  </div>

  <div>
    <%= form.label :goals_for, style: "display: block" %>
    <%= form.number_field :goals_for %>
  </div>

  <div>
    <%= form.label :goals_against, style: "display: block" %>
    <%= form.number_field :goals_against %>
  </div>

  <div>
    <%= form.label :goal_difference, style: "display: block" %>
    <%= form.number_field :goal_difference %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
