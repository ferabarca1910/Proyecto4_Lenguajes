<div id="<%= dom_id team %>">
  <p>
    <strong>Country name:</strong>
    <%= team.country_name %>
  </p>

  <p>
    <strong>Group:</strong>
    <%= team.group_id %>
  </p>

  <p>
    <strong>Points:</strong>
    <%= team.points %>
  </p>

  <p>
    <strong>Goals for:</strong>
    <%= team.goals_for %>
  </p>

  <p>
    <strong>Goals against:</strong>
    <%= team.goals_against %>
  </p>

  <p>
    <strong>Goal difference:</strong>
    <%= team.goal_difference %>
  </p>

</div>
